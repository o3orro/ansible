
#!/bin/bash -eu
# SPDX-License-Identifier: MIT
{{ ansible_managed | comment }}
{{ "system_role:trustee_client" | comment(prefix="", postfix="") }}
#
# Secret Registration Client - registers with the server using attestation,
# then fetches the disk encryption key from Trustee KBS.
#
# Usage:
#   --fetch-key-to <secret_output_path>  Write the disk encryption key to the given path
#   --mount-disk                        Fetch key and mount the encrypted disk
#
set -o pipefail

REGISTRATION_SERVER_URL="{{ trustee_client_kbs_url }}"
REGISTRATION_SERVER_PORT="8081"
CDH_URL="http://127.0.0.1:8006"
RESOURCE_REPOSITORY="disk-encryption"
KEY_TAG="luks-key-0"
MOUNT_POINT="{{ trustee_client_encrypt_disk_mount_point }}"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $*"; }
die() { log "ERROR: $*"; exit 1; }

fetch_key() {
    local secret_output_path="$1"
    local client_id=$(cat /etc/machine-id)
    local secret_url="${CDH_URL}/cdh/resource/${RESOURCE_REPOSITORY}/${client_id}/${KEY_TAG}"
    curl -sf --connect-timeout 10 -o "$secret_output_path" "$secret_url" 2>/dev/null
    if [ $? -ne 0 ]; then
        # Register with server
        local registration_url="${REGISTRATION_SERVER_URL%:*}:${REGISTRATION_SERVER_PORT}/register-encryption-key"
        local attestation_token=$(curl -sf --connect-timeout 10 "${CDH_URL}/aa/token?token_type=kbs" | jq -r '.token')
        local json=$(jq -n --arg token "$attestation_token" --arg id "$client_id" '{attestation_token:$token,client_id:$id}')
        curl -sf --connect-timeout 10 -X POST -H "Content-Type: application/json" --cacert /etc/trustee-gc/server.crt -d "$json" "$registration_url" > /dev/null || die "Failed to register with server"
        curl -sf --connect-timeout 10 -o "$secret_output_path" "$secret_url" || die "Failed to fetch key from KBS"
    fi
    chmod 600 "$secret_output_path"
    log "Key fetched and written to $secret_output_path"
}

mount_disk() {
    if mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
        log "Already mounted at $MOUNT_POINT"
        return
    fi
    local disk_partition key_path
    # Find the first unmounted LUKS partition
    local part
    for part in $(blkid -t TYPE=crypto_LUKS -o device 2>/dev/null); do
        if ! lsblk -n -o MOUNTPOINT "$part" 2>/dev/null | grep -q .; then
            disk_partition="$part"
            break
        fi
    done
    if [ -z "$disk_partition" ]; then
        die "No unmounted LUKS partition found"
    fi
    key_path=$(mktemp --suffix=.key) || die "Failed to create temp file"
    trap 'rm -f "$key_path"' EXIT
    fetch_key "$key_path"
    mkdir -p "$MOUNT_POINT" || die "Failed to create mount point directory"
    cryptsetup open --key-file "$key_path" "$disk_partition" trustee_client_encrypted_disk_0 || die "Failed to open encrypted disk"
    mount /dev/mapper/trustee_client_encrypted_disk_0 "$MOUNT_POINT" || die "Failed to mount encrypted disk"
    log "Mounted encrypted disk at $MOUNT_POINT"
}

case "${1:-}" in
    --fetch-key-to)
        [[ -n "${2:-}" ]] || die "--fetch-key-to requires <secret_output_path>"
        fetch_key "$2"
        ;;
    --mount-disk)
        mount_disk
        ;;
    *)
        die "Usage: $0 --fetch-key-to <secret_output_path> | --mount-disk"
        ;;
esac
