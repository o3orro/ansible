{{ ansible_managed | comment }}
{{ "system_role:auditd" | comment(prefix="", postfix="") }}

# Delete all previous rules
-D
# Set buffer size
-b {{ auditd_buffer_size }}
# Set failure behavior
-f {{ auditd_fail_mode }}
# Set the maximum amount of messages per second
-r {{ auditd_maximum_rate | int }}
# This determine how long to wait in burst of events
--backlog_wait_time {{ auditd_backlog_wait_time | int }}
{% if auditd_loginuid_immutable %}
# Make loginuid immutable
--loginuid-immutable
{% endif %}
# Set enable flag (0=disable, 1=enable, 2=locked, requires reboot to unlock)
-e {{ auditd_enable_flag }}

{% for rule in auditd_rules | d([]) %}
{%   set __arch_loop = ([''] if (not rule.arch is defined) or (rule.arch is string and rule.arch == 'nowarn') else ([rule.arch] if (rule.arch is string) else (rule.arch | list))) %}
{%   for __a in __arch_loop %}
{%     set __flist = ([rule.field] if (rule.field is defined and rule.field is string) else (rule.field | default([]) | list)) %}
{%     set __klist = ([rule.keyname] if (rule.keyname is defined and (rule.keyname is string or rule.keyname is number)) else (rule.keyname | default([]) | list)) %}
-a {{ rule.action }},{{ rule.filter -}}
{%-    if (__a | string | trim | length) > 0 %} -F arch={{ __a }}{% endif -%}
{%-    if rule.syscall is defined %}{% if rule.syscall is string or rule.syscall is number %} -S {{ rule.syscall }}{% else %} -S {{ rule.syscall | map('string') | join(',') }}{% endif %}{% endif -%}
{%-    if rule.path is defined %} -F path={{ rule.path }}{% endif -%}
{%-    if rule.dir is defined %} -F dir={{ rule.dir }}{% endif -%}
{%-    if rule.permission is defined %}
{%-      set __p_raw = rule.permission %}
{%-      set __plist = ([__p_raw] if (__p_raw is string) else (__p_raw | list)) %}
{%-      if not (
           (__p_raw is string and __p_raw == 'nowarn')
            or (__p_raw is iterable and __p_raw is not string and (__plist | length == 1) and ((__plist | first) == 'nowarn'))
         ) %} -F perm={% for p in __plist %}{{ __auditd_permissions[p] }}{% endfor %}{% endif -%}
{%-      endif -%}
{%-   for f in __flist %} -F {{ f }}{% endfor -%}
{%-   for k in __klist %} -F key={{ k }}{% endfor %}

{%   endfor %}
{% endfor %}
