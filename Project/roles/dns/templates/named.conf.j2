options {
        listen-on port 53 { any; };
        listen-on-v6 port 53 { none; };
        directory       "/var/named";
        allow-query     { any; };
        recursion yes;
        
        forwarders {
                8.8.8.8;
        };
};

zone "{{ dns_domain }}" IN {
        type master;
        file "{{ dns_domain }}.zone";
};

zone "{{ reverse_zone }}" IN {
        type master;
        file "{{ reverse_zone_file }}";
};